---
import {
    getCollection,
    render,
} from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { SITE_CONFIG } from "@/config";
import TextReveal from "@/components/ui/TextReveal";
import ArticleAnimate from "@/components/ui/ArticleAnimate";
import FadeContent from "@/components/ui/FadeContent";

export async function getStaticPaths() {
    const pages =
        await getCollection(
            "pages",
        );

    const pagePaths =
        pages.map(
            (
                page: CollectionEntry<"pages">,
            ) => ({
                params: {
                    slug: page.id,
                },
                props: {
                    entry: page,
                },
            }),
        );

    return pagePaths;
}

const {
    entry,
} =
    Astro.props;

const {
    Content,
} =
    await render(
        entry,
    );
---

<Layout
    title={entry
        .data
        .title}
    description={entry
        .data
        .description || `${entry.data.title} - ${SITE_CONFIG.title}`}
    rawContentUrl={`/raw/pages/${entry.id}.md`}
>
    <article class="max-w-3xl mx-auto pt-20" data-pagefind-body>
        <header class="mb-20 text-left">
            <TextReveal
                client:load
                text={
                    entry
                        .data
                        .title
                }
                type="char"
                className="text-3xl md:text-5xl font-bold tracking-tight leading-tight mb-8"
            />

            {entry
                .data
                .description && (
                <FadeContent
                    client:load
                    delay={
                        200
                    }
                    duration={
                        700
                    }
                    blur={
                        true
                    }
                >
                    <p class="text-lg md:text-xl text-primary-text text-left leading-[1.75] md:leading-[1.7]">
                        {
                            entry
                                .data
                                .description
                        }
                    </p>
                </FadeContent>
            )}
        </header>

        <ArticleAnimate
            client:load
            className="prose dark:prose-invert max-w-none prose-headings:font-sans prose-headings:font-bold prose-headings:tracking-tight prose-a:text-black dark:prose-a:text-white prose-a:underline prose-a:decoration-1 prose-a:underline-offset-4"
        >
            <Content />
        </ArticleAnimate>
    </article>
</Layout>
