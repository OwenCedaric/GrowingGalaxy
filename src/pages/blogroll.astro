---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import TextReveal from "@/components/ui/TextReveal";
import SpotlightCard from "@/components/ui/SpotlightCard";
import FadeContent from "@/components/ui/FadeContent";
import { SITE_CONFIG } from "@/config";
type BlogrollEntry = CollectionEntry<"blogroll">;

const blogroll =
    await getCollection(
        "blogroll",
    );

blogroll.sort(
    (
        a: BlogrollEntry,
        b: BlogrollEntry,
    ) =>
        a.data.name.localeCompare(
            b
                .data
                .name,
        ),
);
---

<Layout
    title=`Blogroll | ${SITE_CONFIG.title}`
    description="A collection of friends and interesting links."
>
    <div
        class="max-w-4xl mx-auto pt-20 px-6"
    >
        <div
            class="fixed top-0 right-0 h-screen z-[-10] select-none pointer-events-none overflow-hidden flex items-center justify-center"
        >
            <TextReveal
                client:load
                text="Blogroll"
                type="char"
                className="font-bold text-black/[0.03] dark:text-white/[0.15] text-[6vh] lg:text-[10vh] leading-none whitespace-nowrap"
                style={{
                    writingMode:
                        "vertical-rl",
                    textOrientation:
                        "mixed",
                }}
            />
        </div>

        <div
            class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16"
        >
            {
                blogroll.map(
                    (
                        entry: BlogrollEntry,
                        index: number,
                    ) => (
                        <FadeContent
                            client:visible
                            delay={
                                index *
                                80
                            }
                            duration={
                                700
                            }
                            blur={
                                true
                            }
                        >
                            <SpotlightCard
                                client:visible
                                className="p-1"
                            >
                                <article class="flex flex-row gap-6 group items-start relative z-10">
                                    <div class="relative w-20 h-20 flex-shrink-0 rounded-full overflow-hidden border border-black/10 dark:border-white/10 group-hover:border-black/30 dark:group-hover:border-white/30 transition-colors">
                                        <img
                                            src={
                                                entry
                                                    .data
                                                    .avatar
                                            }
                                            alt={
                                                entry
                                                    .data
                                                    .name
                                            }
                                            loading="lazy"
                                            decoding="async"
                                            class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-500"
                                        />
                                    </div>

                                    <div class="space-y-3">
                                        <a
                                            href={
                                                entry
                                                    .data
                                                    .link
                                            }
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="block"
                                        >
                                            <h2 class="text-2xl font-bold tracking-tight hover:text-secondary-text transition-colors">
                                                {
                                                    entry
                                                        .data
                                                        .name
                                                }
                                            </h2>
                                        </a>

                                        <p class="text-base text-secondary-text leading-relaxed">
                                            {
                                                entry
                                                    .data
                                                    .description
                                            }
                                        </p>
                                    </div>
                                </article>
                            </SpotlightCard>
                        </FadeContent>
                    ),
                )
            }
        </div>
    </div>
</Layout>
