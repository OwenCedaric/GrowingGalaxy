---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type {
    GetStaticPaths,
    InferGetStaticPropsType,
} from "astro";
import { SITE_CONFIG } from "@/config";
import Layout from "@/layouts/Layout.astro";
import TextReveal from "@/components/ui/TextReveal";
import SpotlightCard from "@/components/ui/SpotlightCard";
import FadeContent from "@/components/ui/FadeContent";
import ScrollFloat from "@/components/ui/ScrollFloat";

type BlogPost =
    CollectionEntry<"blog">;

export const getStaticPaths =
    (async ({
        paginate,
    }) => {
        const posts =
            (
                await getCollection(
                    "blog",
                )
            ).sort(
                (
                    a: BlogPost,
                    b: BlogPost,
                ) =>
                    b.data.pubDate.valueOf() -
                    a.data.pubDate.valueOf(),
            );

        return paginate(
            posts,
            {
                pageSize:
                    SITE_CONFIG.postsPerPage,
            },
        );
    }) satisfies GetStaticPaths;

type Props =
    InferGetStaticPropsType<
        typeof getStaticPaths
    >;

const {
    page,
} =
    Astro.props;
---

<Layout
    title={`BLOG // ${SITE_CONFIG.title}`}
    description={SITE_CONFIG.description}
>
    <div
        class="max-w-4xl mx-auto pt-4 md:pt-6 px-6"
    >
        <div
            class="fixed top-0 right-0 h-screen z-[-10] select-none pointer-events-none overflow-hidden flex items-center justify-center"
        >
            <TextReveal
                client:load
                text="Blog"
                type="char"
                className="font-bold text-black/[0.03] dark:text-white/[0.15] text-[10vh] lg:text-[18vh] leading-none whitespace-nowrap"
                style={{
                    writingMode:
                        "vertical-rl",
                    textOrientation:
                        "mixed",
                }}
            />
        </div>

        <div class="flex flex-col gap-4 sm:gap-6 md:gap-8">
            {
                page.data.map(
                    (
                        post: BlogPost,
                        index: number,
                    ) => (
                        <FadeContent
                            client:visible
                            className="w-full"
                            delay={index * 100}
                            duration={800}
                            blur={true}
                        >
                            <SpotlightCard
                                client:visible
                                className="p-4 sm:p-5 md:p-6"
                            >
                                <article class="flex flex-col md:flex-row gap-2.5 md:gap-8 group relative z-10 md:items-baseline">
                                    <div class="w-full md:w-24 flex-shrink-0 flex md:flex-col items-center md:items-start gap-2.5 md:gap-1.5 pt-0.5 md:pt-0 mt-0 md:mt-1.5">
                                        <div class="text-gray-400 dark:text-gray-500 font-mono text-[11px] md:text-xs opacity-70">
                                            {`${post.data.pubDate.getFullYear()}.${String(post.data.pubDate.getMonth() + 1).padStart(2, '0')}.${String(post.data.pubDate.getDate()).padStart(2, '0')}`}
                                        </div>
                                        <span class="w-1 h-1 rounded-full bg-gray-200 dark:bg-gray-700 md:hidden"></span>
                                        <div class="text-[9.5px] md:text-[10px] font-medium uppercase tracking-widest text-gray-400 dark:text-gray-500 opacity-60">
                                            {post.data.category}
                                        </div>
                                    </div>

                                    <div class="flex-1 space-y-1.5 md:space-y-3">
                                        <a
                                            href={`/blog/${post.id}`}
                                            class="block after:absolute after:inset-0 after:z-20 after:cursor-pointer"
                                        >
                                            <h2 class="text-[17px] md:text-xl font-medium tracking-wide hover:text-secondary-text transition-colors leading-snug md:leading-normal">
                                                <ScrollFloat
                                                    client:visible
                                                    text={post.data.title}
                                                    className="text-[17px] md:text-xl font-medium tracking-wide"
                                                    scrollStart="top bottom-=50"
                                                    scrollEnd="top center+=100"
                                                    stagger={0.02}
                                                />
                                            </h2>
                                        </a>

                                        <p class="text-[13px] md:text-sm text-gray-500 dark:text-gray-400 leading-relaxed font-light line-clamp-2 md:line-clamp-none">
                                            {post.data.description}
                                        </p>
                                    </div>
                                </article>
                            </SpotlightCard>
                        </FadeContent>
                    ),
                )
            }
        </div>

        <!-- Pagination Navigation -->
        <div
            class="flex justify-between items-center mt-16 pt-12 border-t border-black/5 dark:border-white/5 opacity-60 dark:opacity-80"
        >
            {
                page
                    .url
                    .prev ? (
                    <a
                        href={
                            page
                                .url
                                .prev
                        }
                        class="text-sm font-medium hover:text-black dark:hover:text-white transition-colors"
                    >
                        ←
                        Previous
                    </a>
                ) : (
                    <span />
                )
            }
            <span class="text-xs font-mono">
                Page {page.currentPage} of {page.lastPage}
            </span>
            {
                page
                    .url
                    .next ? (
                    <a
                        href={
                            page
                                .url
                                .next
                        }
                        class="text-sm font-medium hover:text-black dark:hover:text-white transition-colors"
                    >
                        Next
                        →
                    </a>
                ) : (
                    <span />
                )
            }
        </div>
    </div>
</Layout>
