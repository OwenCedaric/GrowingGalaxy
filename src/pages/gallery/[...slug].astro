---
import Layout from "@/layouts/Layout.astro";
import { SITE_CONFIG } from "@/config";
import { getPhotos } from "@/utils/photos";
import { TimeRewindAnimation } from "@/components/gallery/TimeRewindAnimation";
import TiltedCard from "@/components/ui/TiltedCard";

import FadeContent from "@/components/ui/FadeContent";
import {
    User,
    MapPin,
    Tag,
} from "lucide-react";

export async function getStaticPaths() {
    const photos =
        await getPhotos();

    return photos.map(
        (
            photo,
            index,
        ) => {
            return {
                params: {
                    slug: photo.slug,
                },
                props: {
                    photo,
                    prevPhoto:
                        index <
                        photos.length -
                            1
                            ? photos[
                                  index +
                                      1
                              ]
                            : null,
                    nextPhoto:
                        index >
                        0
                            ? photos[
                                  index -
                                      1
                              ]
                            : null,
                },
            };
        },
    );
}

const {
    photo,
    prevPhoto,
    nextPhoto,
} =
    Astro.props;
const siteUrl =
    Astro.site
        ? Astro.site
              .toString()
              .replace(
                  /\/$/,
                  "",
              )
        : `${SITE_CONFIG.site}`;
const currentYear =
    new Date().getFullYear();
const startYear =
    (
        SITE_CONFIG.footer as any
    )
        ?.startTime ||
    currentYear;
const yearRange =
    startYear ===
    currentYear
        ? currentYear
        : `${startYear} - ${currentYear}`;

const ldJsons =
    photo.images.map(
        (
            img,
        ) => ({
            "@context":
                "https://schema.org/",
            "@type":
                "ImageObject",
            contentUrl:
                img.url,
            license: `${siteUrl}/license`,
            acquireLicensePage: `${siteUrl}/about`,
            creditText:
                photo.author,
            creator:
                {
                    "@type":
                        "Person",
                    name: photo.author,
                },
            copyrightNotice: `© ${photo.author} ${currentYear}. All rights reserved.`,
            datePublished:
                photo.date,
            keywords:
                photo.tag?.join(
                    ", ",
                ),
            description:
                img.description ||
                photo.name,
            name: photo.name,
            contentLocation:
                photo.location,
        }),
    );

const bodyImages =
    photo.images;
const formattedDate =
    new Date(
        photo.date,
    ).toLocaleDateString(
        "en-US",
        {
            month: "long",
            day: "numeric",
            year: "numeric",
        },
    );
---

<Layout
    title={`${photo.name.replace(/\n/g, " ")} | ${SITE_CONFIG.title}`}
    description={bodyImages[0]
        ?.description ||
        photo.name.replace(
            /\n/g,
            " ",
        )}
>
    <Fragment
        slot="head"
    >
        <meta
            property="og:image"
            content={bodyImages[0]
                ?.url}
        />
        <meta
            property="og:type"
            content="article"
        />
        {
            ldJsons.map(
                (
                    schema,
                ) => (
                    <script
                        type="application/ld+json"
                        is:inline
                        set:html={JSON.stringify(
                            schema,
                        )}
                    />
                ),
            )
        }
    </Fragment>

    <main
        class="w-full max-w-[1800px] mx-auto px-6 md:px-12 lg:px-20 py-8 md:py-16 pt-12 md:pt-20"
    >
        <!-- 1. Header & Metadata -->
        <header
            class="mb-24 md:mb-32 border-b border-zinc-200 dark:border-zinc-800/50 pb-16"
        >
            <h1
                class="max-w-4xl text-5xl md:text-6xl lg:text-7xl font-serif font-medium tracking-tight text-zinc-900 dark:text-zinc-100 leading-[1.15] mb-12"
            >
                {
                    photo.name
                        .split(
                            "\n",
                        )
                        .map(
                            (
                                line,
                            ) => (
                                <div>
                                    {
                                        line
                                    }
                                </div>
                            ),
                        )
                }
            </h1>

            <div
                class="flex flex-col md:flex-row md:items-start md:justify-between gap-8"
            >
                <div
                    class="flex flex-col md:flex-row md:flex-wrap md:items-center gap-4 md:gap-8 text-sm text-zinc-500 dark:text-zinc-400 tracking-wider font-sans font-light"
                >
                    <div
                        class="flex items-center uppercase text-xs font-medium tracking-[0.2em]"
                    >
                        <User
                            className="w-3.5 h-3.5 mr-2 shrink-0 stroke-[2]"
                        />
                        {
                            photo.author
                        }
                    </div>
                    {
                        photo.location && (
                            <div class="flex items-center">
                                <MapPin className="w-3.5 h-3.5 mr-2 shrink-0 stroke-[1.5]" />
                                {
                                    photo.location
                                }
                            </div>
                        )
                    }
                    {
                        photo.tag &&
                            photo
                                .tag
                                .length >
                                0 && (
                                <div class="flex items-center flex-wrap gap-2">
                                    <Tag className="w-3.5 h-3.5 mr-2 shrink-0 stroke-[1.5] hidden md:block" />
                                    <div class="flex items-center md:hidden w-3.5 h-3.5 mr-2 shrink-0">
                                        <Tag className="w-3.5 h-3.5 stroke-[1.5]" />
                                    </div>
                                    <span class="leading-relaxed">
                                        {photo.tag.join(
                                            " · ",
                                        )}
                                    </span>
                                </div>
                            )
                    }
                </div>

                <div
                    class="shrink-0 flex flex-col md:items-end"
                >
                    <TimeRewindAnimation
                        client:visible
                        targetDate={photo.date}
                    />
                </div>
            </div>
        </header>

        <!-- 2. 正文图文区域 -->
        <section
            class="w-full mx-auto flex flex-col gap-24 md:gap-40"
        >
            {
                bodyImages.map(
                    (
                        img,
                        index,
                    ) => {
                        const total =
                            String(
                                bodyImages.length,
                            ).padStart(
                                2,
                                "0",
                            );
                        const num =
                            String(
                                index +
                                    1,
                            ).padStart(
                                2,
                                "0",
                            );
                        const hasText =
                            !!img.description;

                        let layoutType =
                            "hero";
                        if (
                            index ===
                            0
                        ) {
                            layoutType =
                                "hero";
                        } else if (
                            !hasText
                        ) {
                            layoutType =
                                "artwork";
                        } else {
                            const beat =
                                index %
                                4;
                            if (
                                beat ===
                                1
                            )
                                layoutType =
                                    "standard";
                            else if (
                                beat ===
                                2
                            )
                                layoutType =
                                    "cinematic";
                            else if (
                                beat ===
                                3
                            )
                                layoutType =
                                    "alternate";
                            else
                                layoutType =
                                    "editorial";
                        }

                        const isEditorialText =
                            layoutType ===
                                "editorial" ||
                            layoutType ===
                                "hero";

                        return (
                            <FadeContent
                                client:visible
                                delay={
                                    index *
                                    150
                                }
                                duration={
                                    1000
                                }
                                blur={
                                    true
                                }
                                className={`group w-full ${layoutType === "editorial" ? "my-24 md:my-40" : ""}`}
                            >
                                <div
                                    class={`relative w-full flex flex-col ${
                                        layoutType ===
                                        "hero"
                                            ? "items-center gap-6 md:gap-10"
                                            : layoutType ===
                                                "artwork"
                                              ? "items-center gap-6 md:gap-10"
                                              : layoutType ===
                                                  "cinematic"
                                                ? "flex-col items-center gap-8 md:gap-12"
                                                : layoutType ===
                                                    "alternate"
                                                  ? "md:flex-row-reverse items-center justify-between gap-12 md:gap-20"
                                                  : layoutType ===
                                                      "editorial"
                                                    ? "md:flex-row items-center justify-between gap-12 md:gap-24"
                                                    : "md:flex-row items-center justify-between gap-12 md:gap-20"
                                    }`}
                                >
                                    {/* Sleek Magazine Numbering Plate */}
                                    {(layoutType ===
                                        "cinematic" ||
                                        layoutType ===
                                            "hero" ||
                                        layoutType ===
                                            "artwork") && (
                                        <div class="flex items-center gap-4 text-xs uppercase tracking-[0.2em] font-sans font-medium text-zinc-400 dark:text-zinc-500 mb-2">
                                            <span class="w-8 h-[1px] bg-zinc-300 dark:bg-zinc-700" />
                                            N°{" "}
                                            {
                                                num
                                            }{" "}
                                            &mdash;{" "}
                                            {
                                                total
                                            }
                                        </div>
                                    )}

                                    {/* Image Container */}
                                    <div
                                        class={`relative shrink-0 flex flex-col items-center justify-center ${
                                            layoutType ===
                                            "hero"
                                                ? "w-full"
                                                : layoutType ===
                                                    "artwork"
                                                  ? "w-full md:w-[85%]"
                                                  : layoutType ===
                                                      "cinematic"
                                                    ? "w-full md:w-[90%]"
                                                    : layoutType ===
                                                        "editorial"
                                                      ? "w-full md:w-[45%]"
                                                      : "w-full md:w-[50%]"
                                        }`}
                                    >
                                        {(layoutType ===
                                            "standard" ||
                                            layoutType ===
                                                "alternate" ||
                                            layoutType ===
                                                "editorial") && (
                                            <div
                                                class={`absolute -top-10 md:-top-12 text-xs uppercase tracking-[0.2em] font-sans font-medium text-zinc-400 dark:text-zinc-500 ${
                                                    layoutType ===
                                                    "alternate"
                                                        ? "right-0"
                                                        : "left-0"
                                                }`}
                                            >
                                                N°{" "}
                                                {
                                                    num
                                                }
                                            </div>
                                        )}

                                        <TiltedCard
                                            client:load
                                            imageSrc={
                                                img.url
                                            }
                                            altText={
                                                img.alt ||
                                                "Gallery Photo"
                                            }
                                            captionText=""
                                            containerHeight="auto"
                                            containerWidth="100%"
                                            imageHeight="auto"
                                            imageWidth="auto"
                                            imageClassName={`w-auto h-auto object-contain shadow-2xl shadow-black/10 dark:shadow-black/40 ring-1 ring-black/5 dark:ring-white/10 ${
                                                layoutType ===
                                                "editorial"
                                                    ? "max-h-[70vh] rounded-t-[3rem] rounded-b-2xl"
                                                    : layoutType ===
                                                        "cinematic"
                                                      ? "max-h-[85vh] rounded-md md:rounded-xl"
                                                      : layoutType ===
                                                          "alternate"
                                                        ? "max-h-[85vh] rounded-tr-[3rem] rounded-bl-[3rem] rounded-tl-xl rounded-br-xl"
                                                        : layoutType ===
                                                            "artwork"
                                                          ? "max-h-[85vh] rounded-md md:rounded-xl"
                                                          : layoutType ===
                                                              "hero"
                                                            ? "max-h-[85vh] rounded-none sm:rounded-2xl"
                                                            : "max-h-[85vh] rounded-2xl"
                                            }`}
                                            rotateAmplitude={
                                                layoutType ===
                                                    "hero" ||
                                                layoutType ===
                                                    "cinematic"
                                                    ? 3
                                                    : 5
                                            }
                                            scaleOnHover={
                                                1.01
                                            }
                                            showMobileWarning={
                                                false
                                            }
                                            showTooltip={
                                                false
                                            }
                                            displayOverlayContent={
                                                false
                                            }
                                            objectFit="contain"
                                        />
                                    </div>

                                    {/* Text Container */}
                                    {hasText && (
                                        <div
                                            class={`flex flex-col ${
                                                layoutType ===
                                                "hero"
                                                    ? "w-full items-center mt-6 md:mt-10"
                                                    : layoutType ===
                                                        "cinematic"
                                                      ? "w-full items-center mt-6 md:mt-10"
                                                      : layoutType ===
                                                          "editorial"
                                                        ? "flex-1 items-start justify-center md:pr-12"
                                                        : layoutType ===
                                                            "alternate"
                                                          ? "flex-1 items-start justify-center md:pr-12"
                                                          : "flex-1 items-start justify-center md:pl-12"
                                            }`}
                                        >
                                            <div
                                                class={`w-full text-left ${
                                                    layoutType ===
                                                        "hero" ||
                                                    layoutType ===
                                                        "cinematic"
                                                        ? "max-w-2xl flex flex-col gap-6"
                                                        : "flex flex-col gap-6"
                                                }`}
                                            >
                                                {img.description
                                                    ?.split(
                                                        "\n",
                                                    )
                                                    .map(
                                                        (
                                                            p,
                                                        ) =>
                                                            p.trim(),
                                                    )
                                                    .filter(
                                                        Boolean,
                                                    )
                                                    .map(
                                                        (
                                                            paragraph,
                                                            pIdx,
                                                        ) => (
                                                            <p
                                                                class={`tracking-wide break-words inline-block w-full ${
                                                                    isEditorialText &&
                                                                    pIdx ===
                                                                        0
                                                                        ? "text-3xl md:text-5xl font-serif font-medium italic leading-[1.2] text-zinc-900 dark:text-zinc-100 mb-4"
                                                                        : layoutType ===
                                                                            "hero"
                                                                          ? "text-lg md:text-xl font-sans font-light leading-relaxed text-zinc-600 dark:text-zinc-300"
                                                                          : "text-base md:text-lg font-sans font-light leading-relaxed text-zinc-500 dark:text-zinc-400"
                                                                }`}
                                                            >
                                                                {
                                                                    paragraph
                                                                }
                                                            </p>
                                                        ),
                                                    )}
                                            </div>
                                        </div>
                                    )}
                                </div>
                            </FadeContent>
                        );
                    },
                )
            }
        </section>

        <!-- 3. 上一篇 / 下一篇导航 -->
        <footer
            class="mt-16 pt-12 border-t border-black/5 dark:border-white/5 space-y-12"
        >
            <div
                class="flex flex-col sm:flex-row justify-between gap-6"
            >
                <div
                    class="flex-1 text-left"
                >
                    {
                        nextPhoto && (
                            <a
                                href={`/gallery/${nextPhoto.slug}`}
                                class="group block"
                            >
                                <span class="text-xs font-mono uppercase tracking-widest opacity-60 dark:opacity-80 block mb-2 group-hover:opacity-100 transition-opacity">
                                    ←
                                    Next
                                    Post
                                </span>
                                <span class="text-lg font-bold group-hover:underline">
                                    {nextPhoto.name.replace(
                                        /\n/g,
                                        " ",
                                    )}
                                </span>
                            </a>
                        )
                    }
                </div>
                <div
                    class="flex-1 text-right"
                >
                    {
                        prevPhoto && (
                            <a
                                href={`/gallery/${prevPhoto.slug}`}
                                class="group block"
                            >
                                <span class="text-xs font-mono uppercase tracking-widest opacity-60 dark:opacity-80 block mb-2 group-hover:opacity-100 transition-opacity">
                                    Previous
                                    Post
                                    →
                                </span>
                                <span class="text-lg font-bold group-hover:underline">
                                    {prevPhoto.name.replace(
                                        /\n/g,
                                        " ",
                                    )}
                                </span>
                            </a>
                        )
                    }
                </div>
            </div>

            <div
                class="flex justify-between items-center opacity-60 dark:opacity-80"
            >
                <a
                    href="/gallery"
                    class="text-sm font-medium hover:text-black dark:hover:text-white transition-colors"
                >
                    Back
                    to
                    Gallery
                </a>
                <span
                    class="text-xs font-mono"
                >
                    {
                        formattedDate
                    }
                </span>
            </div>
        </footer>
    </main>
</Layout>
