---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";
import GlassCard from "@/components/ui/GlassCard.astro";


interface Props {
    post: any;
}

const {
    post,
} =
    Astro.props;

// Use Provided readingTime or calculate it from the body
// Removed readingTime

const hasImage =
    !!post
        .data
        .heroImage;
---

<a
    href={`/${post.id}`}
    class="block group h-full"
>
    <GlassCard
        class:list={[
            "p-6 h-full flex flex-col gap-5 group-hover:bg-white/80 dark:group-hover:bg-zinc-800/80 group-hover:-translate-y-1 transition-all duration-500",
            !hasImage &&
                "min-h-[320px] justify-center",
        ]}
    >
        {
            hasImage ? (
                <div class="relative overflow-hidden rounded-2xl aspect-[4/3]">
                    <Image
                        src={
                            post
                                .data
                                .heroImage
                        }
                        alt={
                            post
                                .data
                                .title
                        }
                        width={
                            600
                        }
                        height={
                            450
                        }
                        loading="lazy"
                        decoding="async"
                        format="webp"
                        class="object-cover w-full h-full transition-transform duration-700 group-hover:scale-110"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent" />
                </div>
            ) : (
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-12 h-1 px-1 bg-accent/30 rounded-full overflow-hidden">
                        <div class="w-1/3 h-full bg-accent animate-[loading_2s_ease-in-out_infinite]" />
                    </div>
                </div>
            )
        }

        <div
            class="flex-1 flex flex-col gap-3"
        >
            <div
                class="flex items-center gap-2"
            >
                <span
                    class="w-2 h-2 rounded-full bg-accent animate-pulse"
                >
                </span>
                <span
                    class="text-[10px] uppercase tracking-[0.2em] font-sans opacity-60"
                >
                    {
                        post
                            .data
                            .category
                    }
                </span>
            </div>

            <h2
                class:list={[
                    "font-serif leading-tight group-hover:text-accent transition-colors",
                    hasImage
                        ? "text-xl"
                        : "text-3xl",
                ]}
            >
                {
                    post
                        .data
                        .title
                }
            </h2>

            <p
                class:list={[
                    "opacity-70 line-clamp-3 leading-relaxed font-sans font-light",
                    hasImage
                        ? "text-sm"
                        : "text-base",
                ]}
            >
                {
                    post
                        .data
                        .description
                }
            </p>
        </div>

        <div
            class="pt-5 border-t border-border-custom dark:border-border-custom-dark flex justify-between items-center text-[10px] uppercase tracking-widest opacity-60"
        >
            <span
            >
                {
                    post.data.pubDate.toLocaleDateString(
                        "en-US",
                        {
                            month: "short",
                            day: "numeric",
                            year: "numeric",
                        },
                    )
                }
            </span>
            <span
                class="text-accent"
                >{
                    post
                        .data
                        .depth
                }</span
            >
        </div>
    </GlassCard>
</a>

<style
>
    @keyframes loading {
        0% {
            transform: translateX(
                -100%
            );
        }
        100% {
            transform: translateX(
                300%
            );
        }
    }
</style>
