---

<div
    class="fixed inset-0 -z-10 overflow-hidden pointer-events-none"
>
    <div
        class="bg-orb-1 absolute top-[-5%] left-[-5%] h-[50%] w-[50%] rounded-full bg-blue-200/20 dark:bg-blue-500/5 blur-[100px] animate-soft"
    >
    </div>
    <div
        class="bg-orb-2 absolute bottom-[-5%] right-[-5%] h-[50%] w-[50%] rounded-full bg-purple-200/20 dark:bg-purple-500/5 blur-[100px] animate-soft [animation-delay:4s]"
    >
    </div>
</div>

<style
>
    .animate-soft {
        animation: pulse
            12s
            ease-in-out
            infinite;
    }
    @keyframes pulse {
        0%,
        100% {
            opacity: 0.4;
            transform: translate(
                    0,
                    0
                )
                scale(
                    1
                );
        }
        33% {
            opacity: 0.7;
            transform: translate(
                    5%,
                    5%
                )
                scale(
                    1.1
                );
        }
        66% {
            opacity: 0.4;
            transform: translate(
                    -5%,
                    2%
                )
                scale(
                    0.9
                );
        }
    }
</style>
