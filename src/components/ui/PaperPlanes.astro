---
/**
 * PaperPlanes - Decorative paper airplane SVGs with flight trail animations
 * Fills the top-right empty area of the hero section, complementing the
 * foxtail grass SVG at the bottom-right.
 * Paper plane icon from SVGRepo (CC Attribution License)
 */
---

<div
    class="planes-wrapper"
    aria-hidden="true"
>
    <svg
        class="planes-svg"
        viewBox="0 0 500 400"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
    >
        <!-- Flight trail for main plane (dashed curve) -->
        <path
            class="trail trail-1"
            d="M 480 30 C 400 50, 350 35, 300 70 C 250 105, 270 140, 220 165 C 170 190, 130 155, 100 185"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-dasharray="8 5"
            fill="none"
        >
        </path>

        <!-- Flight trail for secondary plane -->
        <path
            class="trail trail-2"
            d="M 440 100 C 380 120, 350 110, 310 135 C 270 160, 280 185, 240 200"
            stroke="currentColor"
            stroke-width="0.9"
            stroke-dasharray="5 6"
            fill="none"
        >
        </path>

        <!-- Main paper airplane (largest, leading the formation) -->
        <g
            class="plane plane-1"
            transform="translate(139, 190) rotate(170) scale(1.8)"
        >
            <path
                d="m2.6 13.083 3.452 1.511L16 9.167l-6 7 8.6 3.916a1 1 0 0 0 1.399-.85l1-15a1.002 1.002 0 0 0-1.424-.972l-17 8a1.002 1.002 0 0 0 .025 1.822z M10 16.167 l4.78 -2.32 L10 20.711 z"
                fill="currentColor"
            >
            </path>
        </g>

        <!-- Secondary paper airplane (medium, trailing behind) -->
        <g
            class="plane plane-2"
            transform="translate(267, 209) rotate(159) scale(1.3)"
        >
            <path
                d="m2.6 13.083 3.452 1.511L16 9.167l-6 7 8.6 3.916a1 1 0 0 0 1.399-.85l1-15a1.002 1.002 0 0 0-1.424-.972l-17 8a1.002 1.002 0 0 0 .025 1.822z M10 16.167 l4.78 -2.32 L10 20.711 z"
                fill="currentColor"
            >
            </path>
        </g>

        <!-- Small accent plane (top-right corner, flying ahead) -->
        <g
            class="plane plane-3"
            transform="translate(410, 55) rotate(-40) scale(1.0)"
        >
            <path
                d="m2.6 13.083 3.452 1.511L16 9.167l-6 7 8.6 3.916a1 1 0 0 0 1.399-.85l1-15a1.002 1.002 0 0 0-1.424-.972l-17 8a1.002 1.002 0 0 0 .025 1.822z M10 16.167 l4.78 -2.32 L10 20.711 z"
                fill="currentColor"
            >
            </path>
        </g>

        <!-- Decorative dots along trail -->
        <circle
            class="dot dot-1"
            cx="370"
            cy="50"
            r="1.8"
            fill="currentColor"
        >
        </circle>
        <circle
            class="dot dot-2"
            cx="310"
            cy="75"
            r="1.2"
            fill="currentColor"
        >
        </circle>
        <circle
            class="dot dot-3"
            cx="260"
            cy="120"
            r="1.5"
            fill="currentColor"
        >
        </circle>
    </svg>
</div>

<style
>
    .planes-wrapper {
        position: absolute;
        right: 10px;
        top: -40px;
        width: 400px;
        height: 340px;
        pointer-events: none;
        opacity: 0;
        animation: planesFadeIn
            1.8s
            ease
            forwards
            1.2s;
    }

    .planes-svg {
        width: 100%;
        height: 100%;
        overflow: visible;
    }

    /* ========================================
       COLOR THEMING (uses @theme token)
       ======================================== */
    .planes-wrapper {
        color: var(
            --color-decoration
        );
    }

    /* ========================================
       TRAIL ANIMATIONS (dash drawing effect)
       ======================================== */
    .trail-1 {
        stroke-dasharray: 8
            5;
        stroke-dashoffset: 400;
        animation: trailDraw
            4s
            ease-out
            forwards
            1.5s;
    }

    .trail-2 {
        stroke-dasharray: 5
            6;
        stroke-dashoffset: 250;
        animation: trailDraw2
            3.5s
            ease-out
            forwards
            2s;
    }

    @keyframes trailDraw {
        to {
            stroke-dashoffset: 0;
        }
    }

    @keyframes trailDraw2 {
        to {
            stroke-dashoffset: 0;
        }
    }

    /* ========================================
       PLANE ANIMATIONS
       ======================================== */
    .plane-1 {
        animation: planeFloat1
            6s
            ease-in-out
            infinite
            2s;
    }

    .plane-2 {
        animation: planeFloat2
            7s
            ease-in-out
            infinite
            2.5s;
    }

    .plane-3 {
        animation: planeFloat3
            8s
            ease-in-out
            infinite
            1.8s;
    }

    @keyframes planeFloat1 {
        0%,
        100% {
            transform: translate(
                    139px,
                    190px
                )
                rotate(
                    170deg
                )
                scale(
                    1.8
                );
        }
        25% {
            transform: translate(
                    135px,
                    184px
                )
                rotate(
                    167deg
                )
                scale(
                    1.8
                );
        }
        50% {
            transform: translate(
                    143px,
                    187px
                )
                rotate(
                    173deg
                )
                scale(
                    1.8
                );
        }
        75% {
            transform: translate(
                    137px,
                    192px
                )
                rotate(
                    169deg
                )
                scale(
                    1.8
                );
        }
    }

    @keyframes planeFloat2 {
        0%,
        100% {
            transform: translate(
                    267px,
                    209px
                )
                rotate(
                    159deg
                )
                scale(
                    1.3
                );
        }
        30% {
            transform: translate(
                    263px,
                    204px
                )
                rotate(
                    156deg
                )
                scale(
                    1.3
                );
        }
        60% {
            transform: translate(
                    271px,
                    212px
                )
                rotate(
                    162deg
                )
                scale(
                    1.3
                );
        }
    }

    @keyframes planeFloat3 {
        0%,
        100% {
            transform: translate(
                    410px,
                    55px
                )
                rotate(
                    -40deg
                )
                scale(
                    1
                );
        }
        35% {
            transform: translate(
                    406px,
                    50px
                )
                rotate(
                    -43deg
                )
                scale(
                    1
                );
        }
        65% {
            transform: translate(
                    414px,
                    58px
                )
                rotate(
                    -37deg
                )
                scale(
                    1
                );
        }
    }

    /* ========================================
       DOT ANIMATIONS (subtle pulse)
       ======================================== */
    .dot-1 {
        animation: dotPulse
            4s
            ease-in-out
            infinite
            2s;
    }

    .dot-2 {
        animation: dotPulse
            5s
            ease-in-out
            infinite
            3s;
    }

    .dot-3 {
        animation: dotPulse
            4.5s
            ease-in-out
            infinite
            2.5s;
    }

    @keyframes dotPulse {
        0%,
        100% {
            opacity: 0.4;
            r: 1;
        }
        50% {
            opacity: 0.8;
            r: 1.8;
        }
    }

    /* ========================================
       FADE IN
       ======================================== */
    @keyframes planesFadeIn {
        from {
            opacity: 0;
            transform: translate(
                20px,
                -10px
            );
        }
        to {
            opacity: 1;
            transform: translate(
                0,
                0
            );
        }
    }

    /* ========================================
       RESPONSIVE
       ======================================== */
    @media (max-width: 1024px) {
        .planes-wrapper {
            width: 280px;
            height: 240px;
            right: 5px;
            top: -20px;
        }
    }

    @media (max-width: 768px) {
        .planes-wrapper {
            display: none;
        }
    }
</style>
