---
import { SITE_CONFIG } from "@/config";
import HarmonicSystemSVG from "./HarmonicSystemSVG.astro";
import HarmonicSystemP5 from "./HarmonicSystemP5.astro";

const { harmonicSystem } = SITE_CONFIG.homepage;
const type = harmonicSystem.type || 'svg';
---

<section
    class="hidden md:flex absolute right-0 top-0 h-full w-[48%] lg:w-[48%] bg-grid flex-col justify-center items-center z-0 transition-all duration-500 slanted-bg"
>
    <div
        class="relative w-full max-w-[340px] aspect-square flex items-center justify-center group"
    >
        {type === 'svg' ? <HarmonicSystemSVG /> : <HarmonicSystemP5 />}

        <div
            class="absolute bottom-[-40px] font-mono text-[9px] text-zinc-400 dark:text-zinc-500 tracking-widest uppercase"
        >
            <span id="label-phase">{type === 'svg' ? 'Δ_PHASE: 0.00' : 'SYSTEM: LORENZ_ATTRACTOR'}</span>
        </div>
    </div>
</section>

